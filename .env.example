# Paradise Automator Environment Variables
# Copy this file to /etc/paradise-automator/.env and fill in your values
# NEVER commit .env to version control!

# ============================================
# REI CLOUD LOGIN CREDENTIALS (Required)
# ============================================
# These credentials are used for automatic login to REI Cloud.

REI_USERNAME=your-email@example.com
REI_PASSWORD=your-password-here

# ============================================
# COMMS CENTRE API CONFIGURATION
# ============================================
# For sending reports via the Comms Centre API

COMMS_API_URL=https://comms.paradisestayz.com.au/api/integrations/v1/send
COMMS_API_KEY=sk_live_your-api-key-here

# Recipient emails (comma-separated list)
EMAIL_TO=cleaner1@example.com,cleaner2@example.com

# CC emails (optional, comma-separated)
EMAIL_CC=manager@example.com

# SMS notification to sender (optional, E164 format e.g. +61412345678)
SMS_SENDER_NOTIFY=+61412345678

# Escalation contact for failures (E164 format)
ESCALATION_PHONE=+61402526638

# Telegram Chat ID for notifications (numeric ID)
# Get yours by messaging @userinfobot on Telegram
TELEGRAM_CHAT_ID=123456789

# ============================================
# PATHS (Optional - defaults shown)
# ============================================
DOWNLOAD_DIR=/app/downloads
